{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "Jwt": {
    "Issuer": "AccessControl",
    "Audience": "AccessControl",
    "ExpiresInHours": 1
  },
  "Mqtt": {
    "Host": "localhost",
    "Port": 1883
  }
}
