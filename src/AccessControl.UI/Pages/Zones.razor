@page "/zones"
@using Flurl.Http
@using AccessControl.UI.Services
@attribute [Authorize]
@inject IZoneService ZoneService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Access Zones</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h5">Access Zones</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenCreateDialog">
        New Zone
    </MudButton>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_zones.Count == 0)
{
    <MudAlert Severity="Severity.Info">No access zones defined.</MudAlert>
}
else
{
    <MudTable Items="_zones" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm" Striped="true">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Description</MudTh>
            <MudTh>Devices</MudTh>
            <MudTh>Profiles</MudTh>
            <MudTh>Created</MudTh>
            <MudTh Style="width: 120px;">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">
                <MudText Typo="Typo.body1"><strong>@context.Name</strong></MudText>
            </MudTd>
            <MudTd DataLabel="Description">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@(context.Description ?? "—")</MudText>
            </MudTd>
            <MudTd DataLabel="Devices">@context.DeviceCount</MudTd>
            <MudTd DataLabel="Profiles">@context.ProfileCount</MudTd>
            <MudTd DataLabel="Created">@context.CreatedAt.ToString("yyyy-MM-dd")</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               OnClick="@(() => OpenEditDialog(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               OnClick="@(() => DeleteZoneAsync(context))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<ZoneItem> _zones = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadZonesAsync();
    }

    private async Task LoadZonesAsync()
    {
        _loading = true;
        try
        {
            _zones = await ZoneService.GetZonesAsync();
        }
        catch (FlurlHttpException ex) when (ex.StatusCode == 401)
        {
            Snackbar.Add("Unauthorized.", Severity.Error);
        }
        catch (FlurlHttpException ex)
        {
            Snackbar.Add($"Failed to load zones (HTTP {ex.StatusCode}).", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load zones: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters<ZoneDialog>
        {
            { x => x.Name, string.Empty },
            { x => x.Description, null }
        };

        var dialog = await DialogService.ShowAsync<ZoneDialog>("New Zone", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: ZoneDialogResult data })
        {
            try
            {
                await ZoneService.CreateZoneAsync(data.Name, data.Description);
                Snackbar.Add("Zone created.", Severity.Success);
                await LoadZonesAsync();
            }
            catch (FlurlHttpException)
            {
                Snackbar.Add("Failed to create zone.", Severity.Error);
            }
        }
    }

    private async Task OpenEditDialog(ZoneItem zone)
    {
        var parameters = new DialogParameters<ZoneDialog>
        {
            { x => x.Name, zone.Name },
            { x => x.Description, zone.Description }
        };

        var dialog = await DialogService.ShowAsync<ZoneDialog>("Edit Zone", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: ZoneDialogResult data })
        {
            try
            {
                await ZoneService.UpdateZoneAsync(zone.Id, data.Name, data.Description);
                Snackbar.Add("Zone updated.", Severity.Success);
                await LoadZonesAsync();
            }
            catch (FlurlHttpException)
            {
                Snackbar.Add("Failed to update zone.", Severity.Error);
            }
        }
    }

    private async Task DeleteZoneAsync(ZoneItem zone)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Zone",
            $"Are you sure you want to delete zone \"{zone.Name}\"?",
            yesText: "Delete", cancelText: "Cancel");

        if (confirmed != true) return;

        try
        {
            await ZoneService.DeleteZoneAsync(zone.Id);
            Snackbar.Add("Zone deleted.", Severity.Success);
            await LoadZonesAsync();
        }
        catch (FlurlHttpException)
        {
            Snackbar.Add("Failed to delete zone.", Severity.Error);
        }
    }
}
