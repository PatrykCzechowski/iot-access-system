@page "/access-profiles"
@using Flurl.Http
@using AccessControl.UI.Services
@attribute [Authorize]
@inject IAccessProfileService ProfileService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Nav

<PageTitle>Access Profiles</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h5">Access Profiles</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenCreateDialog">
        New Profile
    </MudButton>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_profiles.Count == 0)
{
    <MudAlert Severity="Severity.Info">No access profiles defined.</MudAlert>
}
else
{
    <MudTable T="AccessProfileItem" Items="_profiles" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm" Striped="true"
              OnRowClick="@(args => { if (args.Item is not null) Nav.NavigateTo($"/access-profiles/{args.Item.Id}"); })"
              RowClass="cursor-pointer">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Description</MudTh>
            <MudTh>Zones</MudTh>
            <MudTh>Cardholders</MudTh>
            <MudTh Style="width: 60px;"></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">
                <MudText Typo="Typo.body1"><strong>@context.Name</strong></MudText>
            </MudTd>
            <MudTd DataLabel="Description">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@(context.Description ?? "—")</MudText>
            </MudTd>
            <MudTd DataLabel="Zones">@context.ZoneIds.Count</MudTd>
            <MudTd DataLabel="Cardholders">@context.CardholderCount</MudTd>
            <MudTd>
                <span @onclick:stopPropagation="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => DeleteProfileAsync(context))" />
                </span>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<AccessProfileItem> _profiles = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        try
        {
            _profiles = await ProfileService.GetProfilesAsync();
        }
        catch (FlurlHttpException ex) when (ex.StatusCode == 401)
        {
            Snackbar.Add("Unauthorized.", Severity.Error);
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load access profiles.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters<AccessProfileDialog>
        {
            { x => x.Name, string.Empty },
            { x => x.Description, null }
        };

        var dialog = await DialogService.ShowAsync<AccessProfileDialog>("New Access Profile", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: AccessProfileDialogResult data })
        {
            try
            {
                await ProfileService.CreateProfileAsync(data.Name, data.Description);
                Snackbar.Add("Profile created.", Severity.Success);
                await LoadDataAsync();
            }
            catch (FlurlHttpException)
            {
                Snackbar.Add("Failed to create profile.", Severity.Error);
            }
        }
    }

    private async Task DeleteProfileAsync(AccessProfileItem profile)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Profile",
            $"Are you sure you want to delete profile \"{profile.Name}\"?",
            yesText: "Delete", cancelText: "Cancel");

        if (confirmed != true) return;

        try
        {
            await ProfileService.DeleteProfileAsync(profile.Id);
            Snackbar.Add("Profile deleted.", Severity.Success);
            await LoadDataAsync();
        }
        catch (FlurlHttpException)
        {
            Snackbar.Add("Failed to delete profile.", Severity.Error);
        }
    }
}
