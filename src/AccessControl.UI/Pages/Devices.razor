@page "/devices"
@using Flurl.Http
@attribute [Authorize]
@inject IFlurlClient Http
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IDialogService DialogService

<PageTitle>Devices</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h5">Devices</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Search"
               OnClick="ScanForDevices" Disabled="_scanning">
        @if (_scanning)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
        }
        Scan for Devices
    </MudButton>
</MudStack>

@if (_discovered.Count > 0)
{
    <MudText Typo="Typo.h6" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Filled.Wifi" Class="mr-1" />
        Discovered Devices
    </MudText>

    <MudTable Items="_discovered" Hover="true" Dense="true" Elevation="2" Class="mb-6">
        <HeaderContent>
            <MudTh>Model</MudTh>
            <MudTh>IP Address</MudTh>
            <MudTh>Features</MudTh>
            <MudTh>Firmware</MudTh>
            <MudTh>Status</MudTh>
            <MudTh Style="width: 120px;"></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Model</MudTd>
            <MudTd><MudText Typo="Typo.body2" Style="font-family: monospace;">@context.IpAddress</MudText></MudTd>
            <MudTd>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    @foreach (var feature in DeviceHelpers.GetFeatures(context.Features))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@feature</MudChip>
                    }
                </MudStack>
            </MudTd>
            <MudTd>@context.FirmwareVersion</MudTd>
            <MudTd>
                @if (context.AlreadyRegistered)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">Registered</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success">New</MudChip>
                }
            </MudTd>
            <MudTd>
                @if (!context.AlreadyRegistered)
                {
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="@(() => AddDevice(context))">
                        Add
                    </MudButton>
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
}

<MudText Typo="Typo.h6" Class="mb-2">Registered Devices</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_devices.Count == 0)
{
    <MudAlert Severity="Severity.Info">No registered devices. Use "Scan for Devices" to discover and add devices.</MudAlert>
}
else
{
    <MudList T="DeviceItem" ReadOnly="true">
        @foreach (var device in _devices)
        {
            <MudListItem OnClick="@(() => Nav.NavigateTo($"/devices/{device.Id}"))" Style="cursor: pointer;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Router"
                                 Color="@(DeviceHelpers.IsOnline(device.Status) ? Color.Success : Color.Error)" />
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1">@device.Name</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Type: @DeviceHelpers.FormatAdapterType(device.AdapterType)</MudText>
                        </MudStack>
                    </MudStack>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@(DeviceHelpers.IsOnline(device.Status) ? Color.Success : Color.Error)">
                            @device.Status
                        </MudChip>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @device.HardwareId.ToString()[..8]…
                        </MudText>
                    </MudStack>
                </MudStack>
            </MudListItem>
            <MudDivider />
        }
    </MudList>
}

@code {
    private List<DeviceItem> _devices = [];
    private List<DiscoveredDeviceItem> _discovered = [];
    private bool _loading = true;
    private bool _scanning;

    protected override async Task OnInitializedAsync()
    {
        await LoadRegisteredDevicesAsync();
    }

    private async Task LoadRegisteredDevicesAsync()
    {
        _loading = true;
        try
        {
            _devices = await Http
                .Request("api/devices")
                .GetJsonAsync<List<DeviceItem>>();
        }
        catch (FlurlHttpException ex) when (ex.StatusCode == 401)
        {
            Snackbar.Add("Unauthorized.", Severity.Error);
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load devices.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ScanForDevices()
    {
        _scanning = true;
        try
        {
            _discovered = await Http
                .Request("api/devices/scan")
                .PostAsync()
                .ReceiveJson<List<DiscoveredDeviceItem>>();

            if (_discovered.Count == 0)
            {
                Snackbar.Add("No devices found on the network.", Severity.Info);
            }
            else
            {
                Snackbar.Add($"Found {_discovered.Count} device(s).", Severity.Success);
            }
        }
        catch (FlurlHttpException ex) when (ex.StatusCode == 401)
        {
            Snackbar.Add("Unauthorized.", Severity.Error);
        }
        catch (Exception)
        {
            Snackbar.Add("Device scan failed.", Severity.Error);
        }
        finally
        {
            _scanning = false;
        }
    }

    private async Task AddDevice(DiscoveredDeviceItem device)
    {
        var parameters = new DialogParameters<AddDeviceDialog>
        {
            { x => x.Device, device }
        };

        var dialog = await DialogService.ShowAsync<AddDeviceDialog>("Add Device", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await LoadRegisteredDevicesAsync();
            _discovered = _discovered
                .Select(d => d.HardwareId == device.HardwareId
                    ? d with { AlreadyRegistered = true }
                    : d)
                .ToList();
        }
    }
}

