@page "/cards/{Id:guid}"
@using Flurl.Http
@attribute [Authorize]
@inject ICardService CardService
@inject ISnackbar Snackbar

<PageTitle>@(_card?.Label ?? "Card")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_card is null)
{
    <MudAlert Severity="Severity.Error">Card not found.</MudAlert>
}
else
{
    <MudText Typo="Typo.h5" Class="mb-4">@_card.Label</MudText>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.subtitle1" Class="mb-3">General</MudText>
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Active</MudText>
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(_card.IsActive ? Color.Success : Color.Error)">
                            @CardHelpers.FormatIsActive(_card.IsActive)
                        </MudChip>
                    </MudStack>
                    <MudDivider />
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Card UID</MudText>
                        <MudText Typo="Typo.caption" Style="font-family: monospace;">@_card.CardUid</MudText>
                    </MudStack>
                    <MudDivider/>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">User</MudText>
                        <MudText Typo="Typo.caption" Style="font-family: monospace;">@_card.UserId</MudText>
                    </MudStack>
                    <MudDivider/>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Zone</MudText>
                        <MudText Typo="Typo.caption" Style="font-family: monospace;">@_card.ZoneId</MudText>
                    </MudStack>
                    <MudDivider/>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Created</MudText>
                        <MudText Typo="Typo.body2">@_card.CreatedAt.ToLocalTime().ToString("g")</MudText>
                    </MudStack>
                    <MudDivider/>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Last updated</MudText>
                        <MudText Typo="Typo.body2">@_card.UpdatedAt.ToLocalTime().ToString("g")</MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private CardItem? _card;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _card = await CardService.GetCardAsync(Id);
        }
        catch (FlurlHttpException ex) when (ex.StatusCode == 404)
        {
            Snackbar.Add("Card not found.", Severity.Error);
        }
        catch (FlurlHttpException ex) when (ex.StatusCode == 401)
        {
            Snackbar.Add("Unauthorized.", Severity.Error);
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load card.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

}
