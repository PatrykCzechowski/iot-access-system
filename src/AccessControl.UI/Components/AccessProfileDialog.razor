@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="Name" Label="Name" Required="true" MaxLength="100"
                          Variant="Variant.Outlined" />
            <MudTextField @bind-Value="Description" Label="Description" MaxLength="500"
                          Lines="3" Variant="Variant.Outlined" />

            <MudText Typo="Typo.subtitle2" Class="mt-2">Zones</MudText>
            <MudSelect T="Guid" MultiSelection="true" SelectedValues="_selectedZoneIds"
                       SelectedValuesChanged="OnZonesChanged"
                       Label="Select zones" Variant="Variant.Outlined"
                       AnchorOrigin="Origin.BottomCenter"
                       MultiSelectionTextFunc="@(ids => $"{ids.Count()} zone(s) selected")">
                @foreach (var zone in AvailableZones)
                {
                    <MudSelectItem T="Guid" Value="zone.Id">@zone.Name</MudSelectItem>
                }
            </MudSelect>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string Name { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public IEnumerable<Guid> SelectedZoneIds { get; set; } = new HashSet<Guid>();
    [Parameter] public List<ZoneItem> AvailableZones { get; set; } = [];

    private IReadOnlyCollection<Guid> _selectedZoneIds = [];

    protected override void OnInitialized()
    {
        _selectedZoneIds = SelectedZoneIds.ToList();
    }

    private void OnZonesChanged(IReadOnlyCollection<Guid> values)
    {
        _selectedZoneIds = values;
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(Name))
        {
            Snackbar.Add("Name is required.", Severity.Warning);
            return;
        }

        MudDialog.Close(DialogResult.Ok(new AccessProfileDialogResult(
            Name.Trim(), Description?.Trim(), _selectedZoneIds.ToList())));
    }
}
