# PostgreSQL
POSTGRES_USER=db_user
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=access_db

# MQTT (production stack only; docker-compose.infra.yml uses anonymous)
# Keep in sync with mosquitto/password_file when using authenticated broker.
MQTT_USERNAME=mqtt_user
MQTT_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# JWT
JWT_KEY=CHANGE_ME_TO_A_STRONG_SECRET_AT_LEAST_32_BYTES

# Default admin account (created on first startup)
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=Admin1234!
ADMIN_FULLNAME=System Administrator
